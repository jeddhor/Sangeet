{
  "name": "sangeet",
  "version": "0.2.2-alpha",
  "description": "Slick Node.js Navidrome desktop-style web client",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "electron": "electron .",
    "electron:dev": "electron .",
    "pack": "electron-builder --dir",
    "dist:win": "electron-builder --win nsis"
  },
  "keywords": [
    "navidrome",
    "subsonic",
    "music",
    "client"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.sangeet.desktop",
    "productName": "Sangeet",
    "asar": true,
    "files": [
      "electron-main.js",
      "server.js",
      "public/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}